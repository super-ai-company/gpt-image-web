PORT=3000
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_PROVIDER=openai
DEFAULT_MODEL=gpt-image-2

# Optional: set a site access password before exposing this service publicly.
# When empty, the page is accessible without login.
ACCESS_PASSWORD=
ACCESS_SESSION_DAYS=7
# Set true only when the site is served through HTTPS.
ACCESS_COOKIE_SECURE=false

# Optional: expose a browser-side API key input. Keep false for shared deployments.
ALLOW_CLIENT_API_KEY=false

# Optional: override provider/model list.
# PROVIDERS_JSON=[{"id":"openai","name":"OpenAI","baseURL":"https://api.openai.com/v1","apiKeyEnv":"OPENAI_API_KEY","models":["gpt-image-2","gpt-image-1"]}]
